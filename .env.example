# ===========================================================
# pub.dev 发布凭证 — 不要将真实值提交到 git！
# 复制本文件为 .env 填入真实值：
#   cp .env.example .env
# ===========================================================

# 方式一（推荐）：PUB_CREDENTIALS — 完整 JSON 凭证
# 从 pub.dev 的 API Tokens 页面生成，或通过 `dart pub token add` 获取。
# 内容为标准的 OAuth2 JSON 格式：
# {
#   "accessToken": "YOUR_ACCESS_TOKEN",
#   "refreshToken": "YOUR_REFRESH_TOKEN",
#   "tokenEndpoint": "https://accounts.google.com/o/oauth2/token",
#   "scopes": ["openid", "https://www.googleapis.com/auth/userinfo.email"],
#   "expiration": 1234567890
# }
PUB_CREDENTIALS=

# 方式二（Dart SDK >= 2.19）：纯 API Token
# 直接在 pub.dev 的 API Tokens 页面生成的纯字符串 token。
# 配合工作流中的 `--token` 参数使用（见下方注释）。
# PUB_DEV_TOKEN=
